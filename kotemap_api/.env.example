# ============================================================
# KOTE MAP API — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs réelles
# NE JAMAIS committer le fichier .env dans git
# ============================================================

# ------------------------------------
# Base de données PostgreSQL/PostGIS (Supabase gratuit)
# Format asyncpg : postgresql+asyncpg://user:password@host:port/database
# ------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:VOTRE_MOT_DE_PASSE@db.VOTRE_PROJECT.supabase.co:5432/postgres

# ------------------------------------
# Redis (optionnel pour le prototype — laisser vide si non utilisé)
# ------------------------------------
REDIS_URL=redis://localhost:6379

# ------------------------------------
# JWT — Sécurité des tokens
# Générer une clé forte : python -c "import secrets; print(secrets.token_hex(32))"
# ------------------------------------
SECRET_KEY=changez-moi-avec-une-vraie-cle-secrete-de-32-caracteres-minimum
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ------------------------------------
# Anthropic / Claude API
# Obtenir sur : https://console.anthropic.com/
# Laisser vide pour utiliser le fallback local sans IA
# ------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-...

# ------------------------------------
# Firebase Admin SDK (optionnel — non utilisé dans le prototype V1)
# ------------------------------------
FIREBASE_CREDENTIALS_PATH=
